{
  "name": "@optraze/convomem",
  "version": "0.1.0",
  "exports": {
    ".": "./mod.ts",
    "./types": "./types.ts"
  },
  "tasks": {
    "test": "deno test --allow-net --allow-env",
    "test:unit": "deno test tests/unit/ --allow-net --allow-env",
    "test:integration": "deno test tests/integration/ --allow-net --allow-env"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/testing/bdd": "jsr:@std/testing/bdd@1",
    "@std/testing/mock": "jsr:@std/testing/mock@1"
  },
  "publish": {
    "include": [
      "mod.ts",
      "client.ts",
      "types.ts",
      "errors.ts",
      "resources/"
    ],
    "exclude": [
      "tests/",
      "main.ts",
      "main_test.ts"
    ]
  }
}


